<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Your Profile – Tracktern AI Internship Intelligence">
    <title>Profile – Tracktern</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/css/style.css">
    <style>
        /* Profile page extras */
        .profile-header-cta {
            margin-top: 1.25rem;
            display: flex;
            gap: 0.75rem;
            flex-wrap: wrap;
        }

        /* Score display */
        .score-display {
            display: flex;
            align-items: center;
            gap: 1.75rem;
            margin-top: 1.25rem;
            flex-wrap: wrap;
        }
        .score-ring-profile {
            width: 96px; height: 96px; border-radius: 50%;
            background: conic-gradient(#6366f1 var(--score-deg, 0deg), rgba(255,255,255,0.04) 0deg);
            display: flex; align-items: center; justify-content: center;
            position: relative; flex-shrink: 0;
            box-shadow: 0 0 28px rgba(99,102,241,0.35);
        }
        .score-ring-profile::before {
            content: ''; width: 74px; height: 74px; border-radius: 50%;
            background: #0f1729; position: absolute;
        }
        .score-center { position: relative; z-index:1; text-align: center; }
        .score-center .score-n { font-family:'Outfit',sans-serif; font-size:1.5rem; font-weight:800; color:#f8fafc; line-height:1; }
        .score-center .score-d { font-size:0.7rem; color:#64748b; font-weight:600; }

        .score-details { flex: 1; }
        .score-label-pill {
            display: inline-block; padding: 0.3rem 0.85rem; border-radius: 999px;
            font-size: 0.78rem; font-weight: 700; margin-bottom: 0.35rem;
        }
        .score-desc { font-size: 0.82rem; color: #64748b; line-height: 1.4; }

        /* Section heading shortcut */
        .prof-section-title {
            font-family: 'Outfit', sans-serif; font-size: 1.05rem; font-weight: 800;
            color: #f8fafc; display: flex; align-items: center; gap: 0.5rem;
        }
        .prof-section-title i {
            background: linear-gradient(135deg,#6366f1,#06b6d4);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }

        /* Missing skills in profile */
        .missing-skills-wrap { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }

        /* Role cards enhanced */
        .role-match-pill {
            font-size: 0.72rem; font-weight: 700;
            background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2);
            border-radius: 999px; padding: 0.15rem 0.55rem; color: #6ee7b7;
            display: inline-block; margin-top: 0.35rem;
        }

        /* Analysis analyzed-at */
        .analyzed-at {
            font-size: 0.72rem; color: #475569; margin-top: 0.5rem;
            display: flex; align-items: center; gap: 0.35rem;
        }

        /* Empty state */
        .empty-state-box {
            text-align: center; padding: 2rem 1.5rem; color: #475569;
        }
        .empty-state-box i { font-size: 2.5rem; margin-bottom: 0.75rem; display: block; opacity: 0.3; }
        .empty-state-box p { font-size: 0.92rem; line-height: 1.5; }
        .empty-state-box a { color: #6366f1; font-weight: 600; }
    </style>
</head>
<body>
    <nav class="navbar glass-nav">
        <div class="nav-brand"><i class="fa-solid fa-bolt"></i> Tracktern</div>
        <div class="nav-links">
            <span class="user-greeting">Hi, <%= user.name.split(' ')[0] %>!</span>
            <a href="/dashboard"><i class="fa-solid fa-border-all"></i> Dashboard</a>
            <a href="/upload-resume"><i class="fa-solid fa-file-arrow-up"></i> Resume</a>
            <a href="/profile" class="active"><i class="fa-solid fa-user"></i> Profile</a>
            <form action="/logout" method="POST" class="logout-form-inline" onsubmit="return confirm('Log out of Tracktern?');">
                <button type="submit" class="logout-btn"><i class="fa-solid fa-arrow-right-from-bracket"></i> Logout</button>
            </form>
        </div>
    </nav>

    <div class="profile-wrapper">
        <% const analysis = user.resumeAnalysis || {}; %>

        <!-- ── Profile Header ───────────────────────────── -->
        <div class="profile-header glass-card">
            <div class="profile-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
            <div class="profile-header-info">
                <h1 class="profile-name"><%= user.name %></h1>
                <p class="profile-headline">
                    <%= user.branch || 'Student' %><% if (user.year) { %> &nbsp;·&nbsp; <%= user.year %><% } %>
                </p>
                <div class="profile-header-cta">
                    <a href="/upload-resume" class="btn btn-primary sm-btn">
                        <i class="fa-solid fa-file-arrow-up"></i> Update Resume
                    </a>
                    <a href="/dashboard" class="btn btn-secondary sm-btn">
                        <i class="fa-solid fa-border-all"></i> Dashboard
                    </a>
                </div>
            </div>
        </div>

        <!-- ── Info Cards Row ───────────────────────────── -->
        <div class="profile-info-grid">
            <div class="profile-info-card glass-card">
                <i class="fa-solid fa-envelope profile-info-icon"></i>
                <div>
                    <span class="info-label">Email</span>
                    <span class="info-value"><%= user.email %></span>
                </div>
            </div>
            <div class="profile-info-card glass-card">
                <i class="fa-solid fa-graduation-cap profile-info-icon"></i>
                <div>
                    <span class="info-label">Branch</span>
                    <span class="info-value"><%= user.branch || '—' %></span>
                </div>
            </div>
            <div class="profile-info-card glass-card">
                <i class="fa-solid fa-calendar-days profile-info-icon"></i>
                <div>
                    <span class="info-label">Year of Study</span>
                    <span class="info-value"><%= user.year || '—' %></span>
                </div>
            </div>
            <div class="profile-info-card glass-card">
                <i class="fa-solid fa-code profile-info-icon"></i>
                <div>
                    <span class="info-label">Total Skills</span>
                    <span class="info-value"><%= (user.skills || []).length %> detected</span>
                </div>
            </div>
        </div>

        <!-- ── Skills Section ──────────────────────────── -->
        <div class="profile-section glass-card">
            <div class="profile-section-header">
                <h2 class="prof-section-title"><i class="fa-solid fa-microchip"></i> Your Detected Skills</h2>
                <% if (user.skills && user.skills.length > 0) { %>
                    <span class="roles-source-badge badge-ai">
                        <span class="pulse-dot"></span> <%= user.skills.length %> skills
                    </span>
                <% } %>
            </div>
            <% if (user.skills && user.skills.length > 0) { %>
                <div class="skills-list mt-3 flex flex-wrap gap-2">
                    <% user.skills.forEach(skill => { %>
                        <span class="badge"><%= skill %></span>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state-box">
                    <i class="fa-solid fa-microchip"></i>
                    <p>No skills extracted yet. <a href="/upload-resume">Upload your resume</a> to auto-detect skills using AI.</p>
                </div>
            <% } %>
        </div>

        <!-- ── Resume Intelligence ──────────────────────── -->
        <div class="profile-section glass-card" style="border-left: 3px solid #6366f1;">
            <div class="profile-section-header">
                <h2 class="prof-section-title"><i class="fa-solid fa-brain"></i> Resume Intelligence Snapshot</h2>
                <% if (analysis.analyzedAt) { %>
                    <div class="analyzed-at">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                        Last analyzed: <%= new Date(analysis.analyzedAt).toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'}) %>
                    </div>
                <% } %>
            </div>

            <% if ((analysis.detectedSkills && analysis.detectedSkills.length > 0) || (analysis.score && analysis.score > 0)) { %>
                <!-- Score Display -->
                <div class="score-display">
                    <% const score = analysis.score || 0; %>
                    <% const scoreLabel = score >= 80 ? 'Excellent' : score >= 60 ? 'Good' : score >= 40 ? 'Average' : 'Needs Work'; %>
                    <% const scoreClass = score >= 80 ? 'score-excellent' : score >= 60 ? 'score-high' : score >= 40 ? 'score-med' : 'score-low'; %>
                    <div class="score-ring-profile" style="--score-deg:<%= Math.round((score/100)*360) %>deg;">
                        <div class="score-center">
                            <div class="score-n"><%= score %></div>
                            <div class="score-d">/100</div>
                        </div>
                    </div>
                    <div class="score-details">
                        <span class="score-label-pill <%= scoreClass %>"><%= scoreLabel %></span>
                        <div class="progress-bar-wrap" style="margin: 0.35rem 0 0.5rem; max-width: 300px;">
                            <div class="progress-bar-fill" style="width:<%= score %>%;"></div>
                        </div>
                        <p class="score-desc">
                            <% if (score >= 80) { %>Your resume is highly competitive. Focus on tailoring it per role.<% } %>
                            <% if (score >= 60 && score < 80) { %>Good foundation. Add quantified metrics to push above 80.<% } %>
                            <% if (score >= 40 && score < 60) { %>Average profile. Strengthen projects and add more skills.<% } %>
                            <% if (score < 40) { %>Resume needs significant improvement. Follow the suggestions below.<% } %>
                        </p>
                    </div>
                </div>

                <div class="resume-insight-grid mt-3">
                    <div class="resume-insight-card">
                        <h4><i class="fa-solid fa-circle-check"></i> Strengths</h4>
                        <ul>
                            <% if (analysis.strengths && analysis.strengths.length > 0) { %>
                                <% analysis.strengths.forEach(item => { %><li><%= item %></li><% }) %>
                            <% } else { %>
                                <li>Add quantified achievements to strengthen your profile.</li>
                            <% } %>
                        </ul>
                    </div>
                    <div class="resume-insight-card">
                        <h4><i class="fa-solid fa-triangle-exclamation"></i> Weaknesses</h4>
                        <ul>
                            <% if (analysis.weaknesses && analysis.weaknesses.length > 0) { %>
                                <% analysis.weaknesses.forEach(item => { %><li><%= item %></li><% }) %>
                            <% } else { %>
                                <li>No major weaknesses identified.</li>
                            <% } %>
                        </ul>
                    </div>
                    <div class="resume-insight-card">
                        <h4><i class="fa-solid fa-lightbulb"></i> Suggestions</h4>
                        <ul>
                            <% if (analysis.suggestions && analysis.suggestions.length > 0) { %>
                                <% analysis.suggestions.forEach(item => { %><li><%= item %></li><% }) %>
                            <% } else { %>
                                <li>Upload a detailed resume to receive tailored recommendations.</li>
                            <% } %>
                        </ul>
                    </div>
                </div>

                <!-- Missing Skills -->
                <div class="mt-3">
                    <strong style="font-size:0.8rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.5px;font-weight:700;">
                        Missing Skills to Boost Match Scores
                    </strong>
                    <div class="missing-skills-wrap">
                        <% if (analysis.missingSkills && analysis.missingSkills.length > 0) { %>
                            <% analysis.missingSkills.forEach(skill => { %>
                                <span class="badge badge-missing-skill"><i class="fa-solid fa-plus" style="font-size:0.6rem;"></i> <%= skill %></span>
                            <% }) %>
                        <% } else { %>
                            <span class="text-muted text-xs">No major missing skills identified.</span>
                        <% } %>
                    </div>
                </div>

                <!-- AI Bullet Rewrites in profile -->
                <% if (analysis.improvedBullets && analysis.improvedBullets.length > 0) { %>
                <div class="mt-3">
                    <strong style="font-size:0.8rem;color:#94a3b8;text-transform:uppercase;letter-spacing:0.5px;font-weight:700;">
                        AI Bullet Rewrites
                    </strong>
                    <div class="improvement-grid mt-2">
                        <% analysis.improvedBullets.slice(0, 2).forEach(item => { %>
                            <div class="improvement-card">
                                <p class="improvement-label">Original</p>
                                <p class="improvement-original"><%= item.original %></p>
                                <p class="improvement-label">AI Improved</p>
                                <p class="improvement-improved"><%= item.improved %></p>
                            </div>
                        <% }) %>
                    </div>
                </div>
                <% } %>
            <% } else { %>
                <div class="empty-state-box">
                    <i class="fa-solid fa-brain"></i>
                    <p>Upload your resume to unlock AI score, strengths, weaknesses, missing skills, and improvement suggestions.</p>
                    <a href="/upload-resume" class="btn btn-primary sm-btn mt-3" style="display:inline-flex;">
                        <i class="fa-solid fa-file-arrow-up"></i> Analyze Resume
                    </a>
                </div>
            <% } %>
        </div>

        <!-- ── Suggested Roles ──────────────────────────── -->
        <div class="profile-section glass-card" style="border-left: 3px solid #8b5cf6;">
            <div class="profile-section-header">
                <h2 class="prof-section-title"><i class="fa-solid fa-wand-magic-sparkles"></i> Suggested Roles for You</h2>
                <% if (rolesSource === 'ai') { %>
                    <span class="roles-source-badge badge-ai"><i class="fa-solid fa-robot"></i> AI–Powered</span>
                <% } else if (rolesSource === 'static') { %>
                    <span class="roles-source-badge badge-static"><i class="fa-solid fa-bolt"></i> Skill-Based</span>
                <% } %>
            </div>

            <% if (suggestedRoles && suggestedRoles.length > 0) { %>
                <div class="suggested-roles-grid mt-3">
                    <% suggestedRoles.forEach((role, i) => { %>
                        <div class="suggested-role-card">
                            <div class="role-number"><%= i + 1 %></div>
                            <div class="role-body">
                                <span class="role-title"><%= role.title %></span>
                                <span class="role-reason"><%= role.reason %></span>
                                <% if (rolesSource === 'ai') { %>
                                    <span class="role-match-pill"><i class="fa-solid fa-robot"></i> AI Recommended</span>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="empty-state-box">
                    <i class="fa-solid fa-wand-magic-sparkles"></i>
                    <p>No skills extracted yet. <a href="/upload-resume">Upload your resume</a> to get personalized role suggestions from AI.</p>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
